#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

VERSION="$(ruby -Ilib -rslayer_rails/version -e 'print SlayerRails::VERSION')"
TAG="v${VERSION}"

if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "Working tree is not clean. Commit or stash changes before releasing." >&2
  exit 1
fi

if git rev-parse --verify --quiet "$TAG" >/dev/null; then
  echo "Tag ${TAG} already exists." >&2
  exit 1
fi

bundle install
RAILS_ENV=test bundle exec rake dummy:db:schema:load
bundle exec rake

git tag "$TAG"
git push origin HEAD
git push origin "$TAG"

echo "Pushed ${TAG}. The publish workflow will build and publish the gem."
